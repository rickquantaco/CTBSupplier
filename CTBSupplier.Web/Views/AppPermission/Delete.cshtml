@model CTBSupplier.Web.Models.AppPermission
@{
    ViewData["Title"] = "Delete Permission";
}

<h2>Delete Permission</h2>
<div class="alert alert-danger">Are you sure you want to delete this permission? It will be removed from all users.</div>

<dl class="row">
    <dt class="col-sm-3">Description</dt>
    <dd class="col-sm-9">@Model.Description</dd>
</dl>

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="AppPermissionId" />
    <button type="submit" class="btn btn-danger">Yes, Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>

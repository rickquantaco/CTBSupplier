@model IEnumerable<CTBSupplier.Web.Models.AppPermission>
@{
    ViewData["Title"] = "Permissions";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Permissions</h2>
    <a asp-action="Create" class="btn btn-primary">+ New Permission</a>
</div>

<table class="table table-striped table-hover" style="max-width:600px;">
    <thead class="table-dark">
        <tr>
            <th>#</th>
            <th>Description</th>
            <th class="text-end">Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var p in Model)
        {
            <tr>
                <td>@p.AppPermissionId</td>
                <td>@p.Description</td>
                <td class="text-end">
                    <a asp-action="Edit" asp-route-id="@p.AppPermissionId" class="btn btn-sm btn-outline-primary">Edit</a>
                    <a asp-action="Delete" asp-route-id="@p.AppPermissionId" class="btn btn-sm btn-outline-danger">Delete</a>
                </td>
            </tr>
        }
        @if (!Model.Any())
        {
            <tr><td colspan="3" class="text-center text-muted">No permissions defined.</td></tr>
        }
    </tbody>
</table>

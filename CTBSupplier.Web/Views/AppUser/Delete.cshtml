@model CTBSupplier.Web.Models.AppUser
@{
    ViewData["Title"] = "Delete User";
}

<h2>Delete User</h2>
<div class="alert alert-danger">Are you sure you want to delete this user?</div>

<dl class="row">
    <dt class="col-sm-3">Full Name</dt>
    <dd class="col-sm-9">@Model.UserRealName</dd>

    <dt class="col-sm-3">Email</dt>
    <dd class="col-sm-9">@Model.UserEmail</dd>

    <dt class="col-sm-3">Active</dt>
    <dd class="col-sm-9">@(Model.IsActive ? "Yes" : "No")</dd>
</dl>

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="AppUserId" />
    <button type="submit" class="btn btn-danger">Yes, Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>

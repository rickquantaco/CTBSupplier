@model CTBSupplier.Web.Models.ManageSupplierRestrictionsViewModel
@{
    ViewData["Title"] = "Manage Supplier Restrictions";
}

<h2>Manage Supplier Restrictions</h2>
<p class="text-muted">
    User: <strong>@Model.UserRealName</strong> &lt;@Model.UserEmail&gt;
</p>
<p class="text-muted small">
    Tick each supplier this user may access. Leave all unticked to grant access to all suppliers.
</p>

<form asp-action="ManageSupplierRestrictions" asp-route-id="@Model.AppUserId" method="post">
    <input type="hidden" asp-for="AppUserId" />
    <input type="hidden" asp-for="UserRealName" />
    <input type="hidden" asp-for="UserEmail" />

    <div class="card" style="max-width:500px;">
        <div class="card-header">Suppliers</div>
        <ul class="list-group list-group-flush">
            @for (int i = 0; i < Model.Suppliers.Count; i++)
            {
                <li class="list-group-item">
                    <input type="hidden" asp-for="Suppliers[i].SupplierGUID" />
                    <input type="hidden" asp-for="Suppliers[i].SupplierName" />
                    <div class="form-check">
                        <input class="form-check-input"
                               type="checkbox"
                               asp-for="Suppliers[i].IsRestricted"
                               id="sup_@Model.Suppliers[i].SupplierGUID" />
                        <label class="form-check-label" for="sup_@Model.Suppliers[i].SupplierGUID">
                            @Model.Suppliers[i].SupplierName
                        </label>
                    </div>
                </li>
            }
        </ul>
    </div>

    <div class="mt-3">
        <button type="submit" class="btn btn-primary">Save</button>
        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
    </div>
</form>

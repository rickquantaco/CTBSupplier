@model IEnumerable<CTBSupplier.Web.Models.AppUser>
@{
    ViewData["Title"] = "Users";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Users</h2>
    <a asp-action="Create" class="btn btn-primary">+ New User</a>
</div>

<table class="table table-striped table-hover">
    <thead class="table-dark">
        <tr>
            <th>Full Name</th>
            <th>Email</th>
            <th>Active</th>
            <th>Created</th>
            <th class="text-end">Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var u in Model)
        {
            <tr>
                <td>@u.UserRealName</td>
                <td>@u.UserEmail</td>
                <td>
                    @if (u.IsActive)
                    {
                        <span class="badge bg-success">Yes</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">No</span>
                    }
                </td>
                <td>@u.CreatedAt.ToLocalTime().ToString("dd MMM yyyy")</td>
                <td class="text-end">
                    <a asp-action="Edit" asp-route-id="@u.AppUserId" class="btn btn-sm btn-outline-primary">Edit</a>
                    <a asp-action="ManagePermissions" asp-route-id="@u.AppUserId" class="btn btn-sm btn-outline-secondary">Permissions</a>
                    <a asp-action="Delete" asp-route-id="@u.AppUserId" class="btn btn-sm btn-outline-danger">Delete</a>
                </td>
            </tr>
        }
        @if (!Model.Any())
        {
            <tr><td colspan="5" class="text-center text-muted">No users found.</td></tr>
        }
    </tbody>
</table>

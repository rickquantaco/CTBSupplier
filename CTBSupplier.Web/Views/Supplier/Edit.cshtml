@model CTBSupplier.Web.Models.Supplier
@{
    ViewData["Title"] = "Edit Supplier";
}

<h2>Edit Supplier</h2>

<div class="row">
    <div class="col-md-6">
        <form asp-action="Edit" method="post">
            <input type="hidden" asp-for="SupplierGUID" />
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="SupplierName" class="form-label"></label>
                <input asp-for="SupplierName" class="form-control" />
                <span asp-validation-for="SupplierName" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="SupplierAbn" class="form-label"></label>
                <input asp-for="SupplierAbn" class="form-control" />
                <span asp-validation-for="SupplierAbn" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="SupplierCategory" class="form-label"></label>
                <input asp-for="SupplierCategory" class="form-control" />
                <span asp-validation-for="SupplierCategory" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="SupplierDescription" class="form-label"></label>
                <textarea asp-for="SupplierDescription" class="form-control" rows="3"></textarea>
                <span asp-validation-for="SupplierDescription" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Website" class="form-label"></label>
                <input asp-for="Website" class="form-control" />
                <span asp-validation-for="Website" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="SupplierImage" class="form-label"></label>
                <input asp-for="SupplierImage" class="form-control" placeholder="https://..."
                       id="supplierImageInput" />
                <span asp-validation-for="SupplierImage" class="text-danger"></span>
                <img id="supplierImagePreview" src="@Model.SupplierImage" alt="Preview" class="mt-2"
                     style="height:60px;object-fit:contain;border-radius:4px;@(string.IsNullOrWhiteSpace(Model.SupplierImage) ? "display:none;" : "")" />
            </div>

            <div class="mb-3 form-check">
                <input asp-for="IsActive" class="form-check-input" />
                <label asp-for="IsActive" class="form-check-label">Active</label>
            </div>

            <button type="submit" class="btn btn-primary">Save</button>
            <a asp-action="Index" class="btn btn-secondary">Cancel</a>
        </form>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
    <script>
        var input = document.getElementById('supplierImageInput');
        var preview = document.getElementById('supplierImagePreview');
        if (input && preview) {
            input.addEventListener('input', function () {
                var url = this.value.trim();
                if (url) {
                    preview.src = url;
                    preview.style.display = '';
                } else {
                    preview.style.display = 'none';
                }
            });
        }
    </script>
}

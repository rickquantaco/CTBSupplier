@model CTBSupplier.Web.Models.ValidateStockItemUrlsViewModel
@{
    ViewData["Title"] = $"Validate URLs — {Model.Supplier.SupplierName}";
    int passCount = Model.TotalWithUrl - Model.FailedResults.Count;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Validate Stock Item URLs <small class="text-muted fs-5">— @Model.Supplier.SupplierName</small></h2>
    <a asp-action="Details" asp-route-id="@Model.Supplier.SupplierGUID" class="btn btn-secondary">
        &larr; Back to @Model.Supplier.SupplierName
    </a>
</div>

@* Summary card *@
<div class="row g-3 mb-4">
    <div class="col-auto">
        <div class="card text-center px-4 py-2">
            <div class="fs-4 fw-bold">@Model.TotalWithUrl</div>
            <div class="small text-muted">URLs checked</div>
        </div>
    </div>
    <div class="col-auto">
        <div class="card text-center px-4 py-2 border-success">
            <div class="fs-4 fw-bold text-success">@passCount</div>
            <div class="small text-muted">Passed</div>
        </div>
    </div>
    <div class="col-auto">
        <div class="card text-center px-4 py-2 @(Model.FailedResults.Any() ? "border-danger" : "")">
            <div class="fs-4 fw-bold @(Model.FailedResults.Any() ? "text-danger" : "")">@Model.FailedResults.Count</div>
            <div class="small text-muted">Failed</div>
        </div>
    </div>
    @if (Model.TotalWithoutUrl > 0)
    {
        <div class="col-auto">
            <div class="card text-center px-4 py-2 border-warning">
                <div class="fs-4 fw-bold text-warning">@Model.TotalWithoutUrl</div>
                <div class="small text-muted">No URL set</div>
            </div>
        </div>
    }
</div>

@if (!Model.FailedResults.Any())
{
    <div class="alert alert-success">
        <strong>All URLs passed.</strong> Every stock item URL for this supplier responded with a successful HTTP status.
    </div>
}
else
{
    <h5 class="mb-3">Failed URLs <span class="badge bg-danger">@Model.FailedResults.Count</span></h5>

    <table class="table table-sm table-striped table-hover">
        <thead class="table-danger">
            <tr>
                <th>Stock Code</th>
                <th>Description</th>
                <th>URL</th>
                <th>Result</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.FailedResults)
            {
                <tr>
                    <td class="text-nowrap">
                        <a asp-controller="StockItem" asp-action="Edit"
                           asp-route-supplierGuid="@item.SupplierGUID"
                           asp-route-stockCode="@item.StockCode">@item.StockCode</a>
                    </td>
                    <td>@item.StockDesc</td>
                    <td class="text-break">
                        @{ bool urlSafe = item.Url.StartsWith("https://", StringComparison.OrdinalIgnoreCase)
                                       || item.Url.StartsWith("http://",  StringComparison.OrdinalIgnoreCase); }
                        @if (urlSafe)
                        {
                            <a href="@item.Url" target="_blank" rel="noopener">@item.Url</a>
                        }
                        else
                        {
                            <span class="text-muted fst-italic">@item.Url</span>
                        }
                    </td>
                    <td class="text-nowrap">
                        @if (item.StatusCode.HasValue)
                        {
                            <span class="badge bg-danger">HTTP @item.StatusCode</span>
                        }
                        else
                        {
                            <span class="badge bg-warning text-dark" title="@item.ErrorMessage">Error</span>
                            <small class="text-muted ms-1 d-none d-md-inline">@item.ErrorMessage</small>
                        }
                    </td>
                    <td class="text-nowrap">
                        <a asp-controller="StockItem" asp-action="Edit"
                           asp-route-supplierGuid="@item.SupplierGUID"
                           asp-route-stockCode="@item.StockCode"
                           class="btn btn-sm btn-outline-primary">Edit</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

<div class="mt-3">
    <a asp-action="Details" asp-route-id="@Model.Supplier.SupplierGUID" class="btn btn-secondary">
        &larr; Back to @Model.Supplier.SupplierName
    </a>
</div>

@model IEnumerable<CTBSupplier.Web.Models.ApiKey>
@{
    ViewData["Title"] = "API Keys";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>API Keys</h2>
    <a asp-action="Create" class="btn btn-primary">+ Generate New Key</a>
</div>

<p class="text-muted small">
    API keys authenticate calls to <code>GET /api/v1/suppliers</code>.
    Supply the key in the <code>X-API-Key</code> request header.
    The actual key is shown only once at creation — only its hash is stored.
</p>

<table class="table table-striped table-hover">
    <thead class="table-dark">
        <tr>
            <th>Name</th>
            <th>Status</th>
            <th>Created (UTC)</th>
            <th class="text-end">Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var k in Model)
        {
            <tr>
                <td>@k.KeyName</td>
                <td>
                    @if (k.IsActive)
                    {
                        <span class="badge bg-success">Active</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">Revoked</span>
                    }
                </td>
                <td>@k.CreatedAt.ToString("dd MMM yyyy HH:mm")</td>
                <td class="text-end">
                    @if (k.IsActive)
                    {
                        <form asp-action="Revoke" asp-route-id="@k.ApiKeyId" method="post" class="d-inline">
                            <button type="submit" class="btn btn-sm btn-outline-warning"
                                    onclick="return confirm('Revoke this key? Any caller using it will lose access.')">
                                Revoke
                            </button>
                        </form>
                    }
                    else
                    {
                        <form asp-action="Enable" asp-route-id="@k.ApiKeyId" method="post" class="d-inline">
                            <button type="submit" class="btn btn-sm btn-outline-success">Re-enable</button>
                        </form>
                    }
                    <form asp-action="Delete" asp-route-id="@k.ApiKeyId" method="post" class="d-inline">
                        <button type="submit" class="btn btn-sm btn-outline-danger"
                                onclick="return confirm('Permanently delete this key?')">
                            Delete
                        </button>
                    </form>
                </td>
            </tr>
        }
        @if (!Model.Any())
        {
            <tr><td colspan="4" class="text-center text-muted">No API keys yet.</td></tr>
        }
    </tbody>
</table>

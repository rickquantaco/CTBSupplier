@{
    ViewData["Title"] = "Account Inactive";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Account Inactive – CTB Supplier</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
</head>
<body class="bg-light">
    <div class="container d-flex justify-content-center align-items-center" style="min-height:100vh;">
        <div class="card shadow" style="max-width:500px;width:100%;">
            <div class="card-header bg-warning text-dark">
                <h4 class="mb-0">Account Inactive</h4>
            </div>
            <div class="card-body">
                <p class="fs-5">Your account has been deactivated.</p>
                <p class="text-muted">
                    Your email address is registered but your account has been marked as inactive.
                    Please contact your administrator to have your account re-enabled.
                </p>
            </div>
            <div class="card-footer text-end">
                <a href="/" class="btn btn-secondary">Return to Home</a>
            </div>
        </div>
    </div>
</body>
</html>

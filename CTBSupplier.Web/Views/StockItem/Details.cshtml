@model CTBSupplier.Web.Models.StockItem
@{
    ViewData["Title"] = "Stock Item Details";
}

<h2>Stock Item Details</h2>

<div class="card mb-4">
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-3">Stock Code</dt>
            <dd class="col-sm-9">@Model.StockCode</dd>

            <dt class="col-sm-3">Description</dt>
            <dd class="col-sm-9">@Model.StockDesc</dd>

            <dt class="col-sm-3">Brand Name</dt>
            <dd class="col-sm-9">@Model.BrandName</dd>

            <dt class="col-sm-3">Supplier</dt>
            <dd class="col-sm-9">@Model.Supplier?.SupplierName</dd>

            <dt class="col-sm-3">Supplier Stock Code</dt>
            <dd class="col-sm-9">@Model.SupplierStockCode</dd>

            <dt class="col-sm-3">Pricing</dt>
            <dd class="col-sm-9">
                @{
                    var tiers = Model.PricingTiers.OrderBy(t => t.SortOrder).ToList();
                }
                @if (tiers.Count == 1)
                {
                    <span>@tiers[0].SupplierCost.ToString("C") &mdash; @tiers[0].StockUnit @tiers[0].UnitOfMeasurementName</span>
                    @if (!string.IsNullOrWhiteSpace(tiers[0].Notes))
                    {
                        <div class="text-muted small mt-1">@tiers[0].Notes</div>
                    }
                }
                else if (tiers.Count > 1)
                {
                    <table class="table table-sm table-bordered mb-0" style="max-width:560px;">
                        <thead class="table-light">
                            <tr><th>Cost</th><th>Unit</th><th>Unit of Measurement</th><th>Notes</th></tr>
                        </thead>
                        <tbody>
                            @foreach (var tier in tiers)
                            {
                                <tr>
                                    <td>@tier.SupplierCost.ToString("C")</td>
                                    <td>@tier.StockUnit</td>
                                    <td>@tier.UnitOfMeasurementName</td>
                                    <td class="text-muted">@tier.Notes</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <span class="text-muted">—</span>
                }
            </dd>

            <dt class="col-sm-3">Category</dt>
            <dd class="col-sm-9">@Model.StockCategoryName</dd>

            <dt class="col-sm-3">GST Applied</dt>
            <dd class="col-sm-9">@(Model.IsGstApplied ? "Yes" : "No")</dd>

            <dt class="col-sm-3">Media URL</dt>
            <dd class="col-sm-9">
                @if (!string.IsNullOrWhiteSpace(Model.StockMediaUrl))
                {
                    <div class="mb-2">
                        <img src="@Model.StockMediaUrl"
                             alt="Product image for @Model.StockCode"
                             style="width:150px;height:150px;object-fit:contain;border:1px solid #dee2e6;border-radius:4px;" />
                    </div>
                    <a href="@Model.StockMediaUrl" target="_blank" rel="noopener">@Model.StockMediaUrl</a>
                }
            </dd>
        </dl>
    </div>
</div>

<a asp-action="Edit" asp-route-supplierGuid="@Model.SupplierGUID" asp-route-stockCode="@Model.StockCode" class="btn btn-primary">Edit</a>
<a asp-action="Index" class="btn btn-secondary">Back to List</a>

@model CTBSupplier.Web.Models.StockItemIndexViewModel
@{
    ViewData["Title"] = "Stock Items";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Stock Items <small class="text-muted fs-6">(@Model.TotalCount total)</small></h2>
    <a asp-action="Create" class="btn btn-primary">+ New Stock Item</a>
</div>

@* Page size selector *@
<div class="d-flex align-items-center gap-2 mb-3">
    <span class="text-muted small">Per page:</span>
    @foreach (var size in new[] { 25, 50, 100 })
    {
        if (Model.PageSize == size)
        {
            <span class="btn btn-sm btn-dark disabled">@size</span>
        }
        else
        {
            <a asp-action="Index" asp-route-page="1" asp-route-pageSize="@size" class="btn btn-sm btn-outline-secondary">@size</a>
        }
    }
</div>

<table class="table table-striped table-hover">
    <thead class="table-dark">
        <tr>
            <th>Stock Code</th>
            <th>Description</th>
            <th>Brand</th>
            <th>Supplier</th>
            <th>Cost</th>
            <th>Category</th>
            <th>GST</th>
            <th class="text-center" style="width:50px;">&nbsp;</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model.Items)
        {
            <tr>
                <td>
                    <a asp-action="Edit"
                       asp-route-supplierGuid="@item.SupplierGUID"
                       asp-route-stockCode="@item.StockCode">@item.StockCode</a>
                </td>
                <td>@item.StockDesc</td>
                <td>@item.BrandName</td>
                <td>@item.Supplier?.SupplierName</td>
                <td>@item.SupplierCost.ToString("C")</td>
                <td>@item.StockCategoryName</td>
                <td>@(item.IsGstApplied ? "Yes" : "No")</td>
                <td class="text-center">
                    <a asp-action="Delete"
                       asp-route-supplierGuid="@item.SupplierGUID"
                       asp-route-stockCode="@item.StockCode"
                       class="btn btn-sm btn-danger"
                       title="Delete this Stock Item"
                       data-bs-toggle="tooltip">&times;</a>
                </td>
            </tr>
        }
        @if (!Model.Items.Any())
        {
            <tr><td colspan="8" class="text-center text-muted">No stock items found.</td></tr>
        }
    </tbody>
</table>

@* Pagination controls *@
@if (Model.TotalPages > 1)
{
    <nav aria-label="Stock item pages">
        <ul class="pagination">
            <li class="page-item @(Model.Page <= 1 ? "disabled" : "")">
                <a class="page-link" asp-action="Index" asp-route-page="@(Model.Page - 1)" asp-route-pageSize="@Model.PageSize">&#8249;</a>
            </li>

            @for (int p = 1; p <= Model.TotalPages; p++)
            {
                <li class="page-item @(p == Model.Page ? "active" : "")">
                    <a class="page-link" asp-action="Index" asp-route-page="@p" asp-route-pageSize="@Model.PageSize">@p</a>
                </li>
            }

            <li class="page-item @(Model.Page >= Model.TotalPages ? "disabled" : "")">
                <a class="page-link" asp-action="Index" asp-route-page="@(Model.Page + 1)" asp-route-pageSize="@Model.PageSize">&#8250;</a>
            </li>
        </ul>
    </nav>
}

@section Scripts {
    <script>
        // Initialise Bootstrap tooltips
        document.querySelectorAll('[data-bs-toggle="tooltip"]').forEach(el => {
            new bootstrap.Tooltip(el);
        });
    </script>
}
